    "# Download the data for all tickers at once\n",
    "rawdata = yf.download(tickers, start=start_str, end=end_str, auto_adjust=True)\n",
    "\n",
    "# pull only the close price for each ticker\n",
    "prices = rawdata['Close']\n",
    "\n",
    "# Checking to make sure the download is correct, and our date range is working and prices are coming through\n",
    "print(f'Data Shape; {prices.shape[0]} trading days x {prices.shape[1]} tickers')\n",
    "prices.head()"
   ]
  },
