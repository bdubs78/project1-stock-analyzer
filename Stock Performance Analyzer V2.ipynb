    "# Ensure float64 precision before cumulative multiplication\n",
    "daily_returns_clean = daily_returns.astype('float64')\n",
    "\n",
    "# Calculate cumulative returns\n",
    "cumulative_returns = (1 + daily_returns_clean).cumprod() - 1\n",
